# ============================================
# Naturals Salon AI Receptionist — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to git.
# ============================================

# -- VAPI --
VAPI_PRIVATE_KEY=your_vapi_private_key_here
VAPI_PUBLIC_KEY=your_vapi_public_key_here
VAPI_ASSISTANT_ID=your_assistant_id_here
VAPI_ORG_ID=your_org_id_here

# -- n8n --
N8N_BASE_URL=https://your-ngrok-domain.ngrok-free.dev
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here
N8N_DOCKER_DIR=/path/to/your/n8n-docker-directory

# -- Google Sheets --
GOOGLE_SHEETS_ID=your_google_sheets_document_id_here
GOOGLE_SHEETS_CREDENTIAL_ID=your_n8n_sheets_credential_id
GOOGLE_CALENDAR_CREDENTIAL_ID=your_n8n_calendar_credential_id
GMAIL_CREDENTIAL_ID=your_n8n_gmail_credential_id
GOOGLE_CALENDAR_ID=your_google_calendar_id_here

# -- Website --
# Website is hosted on GitHub Pages (no local config needed)
# https://goelakshay11.github.io/ai-receptionist-voice-agent/
